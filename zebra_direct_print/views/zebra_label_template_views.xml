<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_zebra_label_template_form" model="ir.ui.view">
        <field name="name">zebra.label.template.form</field>
        <field name="model">zebra.label.template</field>
        <field name="arch" type="xml">
            <form string="Zebra/TSC Label Template">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Template Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="printer_type"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Template Code" name="code">
                            <field name="body_raw" widget="code" options="{'mode': 'python'}"/>
                            <div class="text-muted mt-2">
                                <p>Use Jinja2 syntax to inject data. Example:</p>
                                <code>^XA^FO50,50^ADN,36,20^FD{{ record.name }}^FS^XZ</code>
                                <p>The `record` variable will be the object you are printing (e.g. `stock.move.line`).</p>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_zebra_label_template_tree" model="ir.ui.view">
        <field name="name">zebra.label.template.tree</field>
        <field name="model">zebra.label.template</field>
        <field name="arch" type="xml">
            <list string="Zebra/TSC Label Templates">
                <field name="name"/>
                <field name="printer_type"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_zebra_label_template" model="ir.actions.act_window">
        <field name="name">Direct Print Templates</field>
        <field name="res_model">zebra.label.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new ZPL/TSPL Label Template
            </p>
        </field>
    </record>

    <!-- Menu Item (Under Inventory > Configuration) -->
    <menuitem id="menu_zebra_label_template" 
              name="Direct Print Templates" 
              parent="stock.menu_stock_config_settings"
              action="action_zebra_label_template" 
              sequence="150"/>
</odoo>
