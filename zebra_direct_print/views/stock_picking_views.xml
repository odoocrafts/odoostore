<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_zebra" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.zebra</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_direct_print_labels" 
                        string="Print ZPL Labels" 
                        type="object" 
                        class="oe_highlight"
                        invisible="state not in ('assigned', 'done')"
                        icon="fa-print"/>
            </xpath>
        </field>
    </record>
</odoo>
