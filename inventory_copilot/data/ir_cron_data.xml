<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_inventory_copilot_recommendations" model="ir.cron">
            <field name="name">Inventory Copilot: Generate AI Recommendations</field>
            <field name="model_id" ref="model_inventory_recommendation"/>
            <field name="state">code</field>
            <field name="code">model.action_generate_recommendations()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_inventory_copilot_health" model="ir.cron">
            <field name="name">Inventory Copilot: Update Health Metrics</field>
            <field name="model_id" ref="model_inventory_health"/>
            <field name="state">code</field>
            <field name="code">model.action_generate_health_metrics()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
