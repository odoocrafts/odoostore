<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_inventory_recommendation_tree" model="ir.ui.view">
        <field name="name">inventory.recommendation.tree</field>
        <field name="model">inventory.recommendation</field>
        <field name="arch" type="xml">
            <list decoration-danger="priority == '3'" decoration-warning="priority == '2'">
                <field name="name"/>
                <field name="product_id"/>
                <field name="action_type"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-muted="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="view_inventory_recommendation_form" model="ir.ui.view">
        <field name="name">inventory.recommendation.form</field>
        <field name="model">inventory.recommendation</field>
        <field name="arch" type="xml">
            <form string="Recommendation">
                <header>
                    <button name="%(stock.action_view_inventory_tree)d" string="View Inventory" type="action" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_id" readonly="1"/>
                            <field name="action_type" readonly="1"/>
                        </group>
                        <group>
                            <field name="priority" widget="priority" readonly="1"/>
                            <field name="confidence_score" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="AI Explanation" name="explanation">
                            <field name="explanation" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_inventory_recommendation_kanban" model="ir.ui.view">
        <field name="name">inventory.recommendation.kanban</field>
        <field name="model">inventory.recommendation</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="product_id"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="action_type"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb16">
                                <div class="o_kanban_record_headings mt4">
                                    <strong class="o_kanban_record_title"><span><t t-esc="record.name.value"/></span></strong>
                                </div>
                                <strong><field name="priority" widget="priority"/></strong>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left text-muted">
                                    <span><t t-esc="record.action_type.value"/></span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'done': 'success', 'cancel': 'default'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_inventory_recommendation" model="ir.actions.act_window">
        <field name="name">AI Recommendations</field>
        <field name="res_model">inventory.recommendation</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No recommendations available!
            </p>
            <p>
                Inventory Copilot will generate recommendations here once issues or optimizations are found.
            </p>
        </field>
    </record>
</odoo>
