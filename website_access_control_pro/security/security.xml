<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Base Restricted Editor (can access website builder but restricted by other groups) -->
        <record id="group_restricted_editor" model="res.groups">
            <field name="name">Restricted Editor (Base)</field>
            <!-- Inherit website restricted editor so they can access the frontend editor -->
            <field name="implied_ids" eval="[(4, ref('website.group_website_restricted_editor'))]"/>
            <field name="comment">Can access website builder but has granular restrictions on what can be edited.</field>
        </record>

        <!-- Menu Admin -->
        <record id="group_menu_admin" model="res.groups">
            <field name="name">Menu Admin</field>
            <field name="implied_ids" eval="[(4, ref('website_access_control_pro.group_restricted_editor'))]"/>
            <field name="comment">Can modify Header, Footer, Main Menu, and Mega Menu.</field>
        </record>

        <!-- Theme Admin -->
        <record id="group_theme_admin" model="res.groups">
            <field name="name">Theme Admin</field>
            <field name="implied_ids" eval="[(4, ref('website_access_control_pro.group_restricted_editor'))]"/>
            <field name="comment">Can change colors, fonts, layout, and header style.</field>
        </record>

        <!-- SEO Admin -->
        <record id="group_seo_admin" model="res.groups">
            <field name="name">SEO Admin</field>
            <field name="implied_ids" eval="[(4, ref('website_access_control_pro.group_restricted_editor'))]"/>
            <field name="comment">Can edit Robots, Canonical URLs, and Redirects.</field>
        </record>

        <!-- Snippet Admin -->
        <record id="group_snippet_admin" model="res.groups">
            <field name="name">Snippet Admin</field>
            <field name="implied_ids" eval="[(4, ref('website_access_control_pro.group_restricted_editor'))]"/>
            <field name="comment">Can insert all snippets, including Forms, Custom HTML, Embedded Scripts.</field>
        </record>

        <!-- Media Delete Admin -->
        <record id="group_media_delete_admin" model="res.groups">
            <field name="name">Media Delete Admin</field>
            <field name="implied_ids" eval="[(4, ref('website_access_control_pro.group_restricted_editor'))]"/>
            <field name="comment">Can delete images from the media library.</field>
        </record>

        <!-- Blog Writer -->
        <record id="group_blog_writer" model="res.groups">
            <field name="name">Blog Writer</field>
            <field name="implied_ids" eval="[(4, ref('website_access_control_pro.group_restricted_editor'))]"/>
            <field name="comment">Can write/edit posts but cannot publish or delete them.</field>
        </record>

        <!-- Blog Publisher -->
        <record id="group_blog_publisher" model="res.groups">
            <field name="name">Blog Publisher</field>
            <field name="implied_ids" eval="[(4, ref('website_access_control_pro.group_blog_writer'))]"/>
            <field name="comment">Can publish blog posts.</field>
        </record>

        <!-- Blog Admin -->
        <record id="group_blog_admin" model="res.groups">
            <field name="name">Blog Admin</field>
            <field name="implied_ids" eval="[(4, ref('website_access_control_pro.group_blog_publisher'))]"/>
            <field name="comment">Can delete blog posts.</field>
        </record>

        <!-- Blog Post Record Rules -->
        <record id="rule_blog_post_delete" model="ir.rule">
            <field name="name">Blog Post Delete Rule</field>
            <field name="model_id" ref="website_blog.model_blog_post"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('website_access_control_pro.group_blog_admin'))]"/>
            <field name="perm_read" eval="0"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="1"/>
        </record>
        
        <record id="rule_blog_post_delete_restrict" model="ir.rule">
            <field name="name">Blog Post Delete Restrict</field>
            <field name="model_id" ref="website_blog.model_blog_post"/>
            <field name="domain_force">[(0,'=',1)]</field>
            <field name="groups" eval="[(4, ref('website_access_control_pro.group_blog_writer'))]"/>
            <field name="perm_read" eval="0"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="1"/>
        </record>

    </data>
</odoo>
